{
      "mappings": {
          "properties": {
              
              "file_id":       {"type": "keyword"},
              "file_name":     {"type": "keyword"},
              "doc_type":      {"type": "keyword"},
              "@timestamp":    {"type": "date"},
              "version":       {"type": "integer"},
              
              "page_number":    {"type": "integer"},
              "chunk_index":    {"type": "integer"},

              
              "content": {
                  "type": "text",
                  "analyzer": "english"              
              },

              
              "embedding": {
                  "type": "dense_vector",
                  "dims": 1024,
                  "index": true,
                  "similarity": "cosine"
              },

              
              "email_id":   {"type": "keyword"},
              "thread_id":  {"type": "keyword"},
              "sender":     {"type": "keyword"},
              "subject": {
                  "type": "text",
                  "fields": { "keyword": {"type": "keyword"} }
              },
              "email_date": {"type": "date"},
            
              "access_type":  {"type": "keyword"},

              "json_metadata": {"type": "flattened"}
          }
      },
      "settings": {
          "number_of_shards":   1,    
          "number_of_replicas": 0   
      }
  }